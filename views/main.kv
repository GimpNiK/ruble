#:kivy 2.3.1
#:import ChartImage charts.ChartImage
#:import PieChart charts.PieChart

<ListItem@BoxLayout>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(34)                  # было 28, увеличено
    spacing: dp(4)
    padding: dp(4), dp(2)
    Label:
        id: date_label
        size_hint_x: 0.22
        font_size: sp(10)
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        color: 0, 0, 0, 1
    Label:
        id: sum_label
        size_hint_x: 0.22
        font_size: sp(10)
        bold: True
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        color: 0, 0, 0, 1
    Label:
        id: descr_label
        size_hint_x: 0.46
        font_size: sp(10)
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        shorten: True
        shorten_from: 'right'
        color: 0, 0, 0, 1
    Button:
        id: delete_btn
        size_hint_x: 0.1
        text: 'X'
        font_size: sp(12)
        background_color: 0.85, 0.25, 0.25, 1
        height: dp(26)              # увеличено
        size_hint_y: None

<MainScreen@Screen>:
    name: 'MainScreen'
    padding: 0
    spacing: 0
    ScrollView:
        do_scroll_x: False
        padding: 0
        spacing: 0
        BoxLayout:
            id: scroll_content
            orientation: 'vertical'
            size_hint_y: None
            height: 1000            # будет пересчитано
            padding: [dp(6), dp(4), dp(6), dp(6)]   # изменено – добавили отступы
            spacing: dp(6)          # изменено – увеличили расстояние между блоками

            Label:
                text: 'Ruble'
                font_size: sp(18)   # немного увеличено
                bold: True
                size_hint_y: None
                height: dp(30)      # увеличено
                color: 0.15, 0.35, 0.65, 1

            BoxLayout:
                size_hint_y: None
                height: dp(36)      # увеличено
                spacing: dp(6)
                padding: dp(6)
                canvas.before:
                    Color:
                        rgba: 0.9, 0.95, 1, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: 'Баланс:'
                    bold: True
                    font_size: sp(12)
                    color: 0, 0, 0, 1
                Label:
                    id: balance
                    bold: True
                    font_size: sp(12)
                    color: 0.1, 0.5, 0.2, 1

            BoxLayout:
                size_hint_y: None
                height: dp(28)      # увеличено
                spacing: dp(4)
                padding: dp(4)
                Label:
                    text: 'Прибыль за месяц:'
                    font_size: sp(11)
                    color: 0, 0, 0, 1
                Label:
                    id: monthly_profit
                    font_size: sp(11)
                    color: 0, 0, 0, 1

            # --- Напоминания ---
            Label:
                text: 'Напоминания'
                bold: True
                size_hint_y: None
                height: dp(22)      # увеличено
                font_size: sp(12)
                color: 0, 0, 0, 1
            BoxLayout:
                id: notifications
                orientation: 'vertical'
                size_hint_y: None
                height: dp(140)     # увеличено

            # --- Транзакции ---
            Label:
                text: 'Транзакции'
                bold: True
                size_hint_y: None
                height: dp(22)
                font_size: sp(12)
                color: 0, 0, 0, 1
            BoxLayout:
                size_hint_y: None
                height: dp(34)      # увеличено
                spacing: dp(6)
                padding: dp(4)
                Button:
                    text: '+ Добавить'
                    font_size: sp(10)
                    size_hint_x: 0.35
                    on_press: root.go_to_transaction()
                Button:
                    text: '<'
                    font_size: sp(14)
                    size_hint_x: None
                    width: dp(36)   # увеличено
                    on_press: root.load_transactions(-1)
                Label:
                    id: tx_page_label
                    text: '0 из 0'
                    font_size: sp(10)
                    size_hint_x: 0.4
                    color: 0, 0, 0, 1
                Button:
                    text: '>'
                    font_size: sp(14)
                    size_hint_x: None
                    width: dp(36)
                    on_press: root.load_transactions(1)
            BoxLayout:
                id: transactions
                orientation: 'vertical'
                size_hint_y: None
                height: dp(140)

            # --- Постоянные платежи ---
            Label:
                text: 'Постоянные платежи'
                bold: True
                size_hint_y: None
                height: dp(22)
                font_size: sp(12)
                color: 0, 0, 0, 1
            BoxLayout:
                size_hint_y: None
                height: dp(34)
                spacing: dp(6)
                padding: dp(4)
                Button:
                    text: '+ Добавить'
                    font_size: sp(10)
                    size_hint_x: 0.35
                    on_press: root.go_to_regular()
                Button:
                    text: '<'
                    font_size: sp(14)
                    size_hint_x: None
                    width: dp(36)
                    on_press: root.load_regular_transactions(-1)
                Label:
                    id: reg_page_label
                    text: '0 из 0'
                    font_size: sp(10)
                    size_hint_x: 0.4
                    color: 0, 0, 0, 1
                Button:
                    text: '>'
                    font_size: sp(14)
                    size_hint_x: None
                    width: dp(36)
                    on_press: root.load_regular_transactions(1)
            BoxLayout:
                id: regular_transactions
                orientation: 'vertical'
                size_hint_y: None
                height: dp(140)

            # --- Период ---
            Label:
                text: 'Период'
                bold: True
                size_hint_y: None
                height: dp(22)
                font_size: sp(12)
                color: 0, 0, 0, 1
            BoxLayout:
                size_hint_y: None
                height: dp(32)      # увеличено
                spacing: dp(4)
                padding: dp(4)
                Label:
                    text: 'С:'
                    font_size: sp(10)
                    size_hint_x: None
                    width: dp(22)   # увеличено
                    color: 0, 0, 0, 1
                TextInput:
                    id: start_date_input
                    multiline: False
                    hint_text: 'ДД.ММ.ГГГГ'
                    font_size: sp(10)
                    height: dp(28)
                    size_hint_y: None
                Label:
                    text: 'По:'
                    font_size: sp(10)
                    size_hint_x: None
                    width: dp(24)
                    color: 0, 0, 0, 1
                TextInput:
                    id: end_date_input
                    multiline: False
                    hint_text: 'ДД.ММ.ГГГГ'
                    font_size: sp(10)
                    height: dp(28)
                    size_hint_y: None
            BoxLayout:
                size_hint_y: None
                height: dp(32)      # увеличено
                spacing: dp(6)
                padding: dp(4)
                Button:
                    text: 'Применить'
                    font_size: sp(10)
                    on_press: root.apply_period()
                Button:
                    text: 'Последний месяц'
                    font_size: sp(10)
                    on_press: root.reset_period()

            # --- Графики ---
            Label:
                text: 'Расходы по категориям'
                bold: True
                size_hint_y: None
                height: dp(22)
                font_size: sp(12)
                color: 0, 0, 0, 1
            BoxLayout:
                size_hint_y: None
                height: 180
                PieChart:
                    id: pie_chart
                    size_hint: (1, 1)

            Label:
                text: 'График доходов и расходов'
                bold: True
                size_hint_y: None
                height: dp(22)
                font_size: sp(12)
                color: 0, 0, 0, 1
            BoxLayout:
                size_hint_y: None
                height: 180
                ChartImage:
                    id: line_chart
                    size_hint: (1, 1)

            Widget:
                size_hint_y: None
                height: dp(12)