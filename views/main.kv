#:kivy 2.3.1

<MainScreen@Screen>:
    name: 'MainScreen'
    BoxLayout:
        orientation: 'vertical'
        BoxLayout:
            orientation: 'horizontal'
            Label:
                text: "Баланс:"
            Label:
                id: balance
        BoxLayout:
            orientation: 'horizontal'
            Label:
                text: "Прибыль за месяц:"
            Label:
                id: monthly_profit
        BoxLayout:
            orientation: 'vertical'
            Label:
                text: "Уведомления об оплате счетов: "
            BoxLayout:
                id: notifications
        BoxLayout:
            orientation: 'vertical'
            Label:
                text: "История транзакций: "
            BoxLayout:
                id: transactions
        BoxLayout:
            orientation: 'vertical'
            Label:
                text: "Постоянные переводы: "
            BoxLayout:
                id: regular_transactions
        BoxLayout:
            orientation: 'horizontal'
            Label:
                text: "Дата начала:"
            Label:
                id: start_date
            Label:
                text: "Дата конца:"
            Label:
                id: end_date
        Label:
            text: "График линейный прибыли и трат"
        Label:
            text: "Столбчатая диаграмма трат по категориям"

<NotificationItem@BoxLayout>:
    orientation: 'horizontal'
    Label:
        id: date
    Label:
        id: sum
    Label:
        id: descr

# Баланс
# Прибыль за месяц
# Уведомления(требования постоянных платежей за 3 дня по умолчанию  проходит)
# История транзакций
#     +- обычная транзакция(5 пунктов сумма и описание возможность раскрытия и пролистывания)
#     +- постоянные переводы(уведомления 5пунктов сумма и описание возможность раскрытия и пролистывания)
# Дата начала и конца по умолчанию последний месяц
# График линейный прибыли и трат
# Столбчатая диаграмма трат по категориям
