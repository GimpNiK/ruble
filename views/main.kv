# main.kv
<MainScreen>:
    name: 'main'
    
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(10)
        
        # Верхняя панель
        BoxLayout:
            size_hint_y: 0.1
            Label:
                text: '🏠 Главная'
                font_size: sp(24)
                bold: True
            Button:
                text: '🚪'
                size_hint_x: 0.15
                font_size: sp(24)
                on_press: root.manager.current = 'login'
        
        # Баланс
        BoxLayout:
            size_hint_y: 0.2
            orientation: 'vertical'
            Label:
                text: 'Текущий баланс'
                font_size: sp(18)
            Label:
                id: balance_label
                text: '125 430 ₽'
                font_size: sp(48)
                bold: True
                color: 0.2, 0.8, 0.2, 1
        
        # Кнопки действий
        BoxLayout:
            size_hint_y: 0.15
            spacing: dp(10)
            Button:
                text: '➕ Доход'
                background_color: 0.2, 0.8, 0.2, 1
                on_press: print('Добавить доход')
            Button:
                text: '➖ Расход'
                background_color: 0.8, 0.2, 0.2, 1
                on_press: print('Добавить расход')
        
        # Последние операции
        Label:
            text: 'Последние операции'
            size_hint_y: 0.05
        
        # Список (пример)
        BoxLayout:
            size_hint_y: 0.4
            orientation: 'vertical'
            spacing: dp(5)
            
            # Элемент списка
            BoxLayout:
                size_hint_y: None
                height: dp(40)
                Label:
                    text: '🍔 Продукты'
                    halign: 'left'
                Label:
                    text: '-1 250 ₽'
                    color: 0.8, 0.2, 0.2, 1
                    halign: 'right'
            
            BoxLayout:
                size_hint_y: None
                height: dp(40)
                Label:
                    text: '💼 Зарплата'
                    halign: 'left'
                Label:
                    text: '+45 000 ₽'
                    color: 0.2, 0.8, 0.2, 1
                    halign: 'right'
        
        # Кнопка перехода к отчетам
        Button:
            text: '📊 Отчеты'
            background_color: 0.5, 0.5, 0.5, 1
            size_hint_y: 0.1
            on_press: root.manager.current = 'reports'