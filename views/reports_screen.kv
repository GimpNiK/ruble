# reports_screen.kv
<ReportsScreen>:
    name: 'reports'
    
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(10)
        
        # Верхняя панель с кнопкой назад
        BoxLayout:
            size_hint_y: 0.1
            Button:
                text: '←'
                size_hint_x: 0.15
                font_size: sp(24)
                on_press: root.manager.current = 'main'
            Label:
                text: '📊 Отчеты'
                font_size: sp(24)
                bold: True
        
        # Выбор периода
        BoxLayout:
            size_hint_y: 0.1
            spacing: dp(5)
            Button:
                text: 'День'
                on_press: root.generate_report()
            Button:
                text: 'Неделя'
            Button:
                text: 'Месяц'
            Button:
                text: 'Год'
        
        # Диаграмма (заглушка)
        BoxLayout:
            size_hint_y: 0.3
            canvas:
                Color:
                    rgba: 0.2, 0.6, 1, 0.3
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: '📊 Диаграмма доходов/расходов'
                color: 0.5, 0.5, 0.5, 1
        
        # Статистика
        BoxLayout:
            size_hint_y: 0.2
            orientation: 'vertical'
            spacing: dp(5)
            
            BoxLayout:
                Label:
                    text: 'Доходы:'
                Label:
                    text: '45 200 ₽'
                    color: 0.2, 0.8, 0.2, 1
            
            BoxLayout:
                Label:
                    text: 'Расходы:'
                Label:
                    text: '28 750 ₽'
                    color: 0.8, 0.2, 0.2, 1
            
            BoxLayout:
                Label:
                    text: 'Чистая прибыль:'
                Label:
                    text: '16 450 ₽'
                    bold: True
        
        # Топ категорий
        Label:
            text: 'Топ категорий расходов'
            size_hint_y: 0.05
        
        BoxLayout:
            size_hint_y: 0.15
            orientation: 'vertical'
            spacing: dp(3)
            
            BoxLayout:
                Label:
                    text: '🍔 Продукты'
                Label:
                    text: '32%'
                    halign: 'right'
            
            BoxLayout:
                Label:
                    text: '🚗 Транспорт'
                Label:
                    text: '18%'
                    halign: 'right'
            
            BoxLayout:
                Label:
                    text: '☕ Кафе'
                Label:
                    text: '15%'
                    halign: 'right'
        
        # Кнопка экспорта
        Button:
            text: '📥 Экспорт отчета'
            size_hint_y: 0.1
            on_press: print('Экспорт в PDF')