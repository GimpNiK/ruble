#:kivy 2.3.1
<AuthScreen@Screen>:
    name: 'AuthScreen'

    BoxLayout:
        orientation: 'vertical'
        padding: dp(24)
        spacing: dp(12)
        canvas.before:
            Color:
                rgba: 0.93, 0.96, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: 'Ruble'
            font_size: sp(28)
            bold: True
            color: 0.15, 0.35, 0.65, 1
            size_hint_y: None
            height: dp(48)

        Label:
            text: 'Создайте PIN-код (4 цифры)'
            size_hint_y: None
            height: dp(28)

        TextInput:
            id: password
            password: True
            multiline: False
            input_filter: 'int'
            max_text_length: 4
            size_hint_y: None
            height: dp(44)

        Label:
            text: 'Повторите PIN-код'
            size_hint_y: None
            height: dp(28)

        TextInput:
            id: password_repeat
            password: True
            multiline: False
            input_filter: 'int'
            max_text_length: 4
            size_hint_y: None
            height: dp(44)

        Label:
            id: message
            text: ''
            color: 0.8, 0.1, 0.1, 1
            size_hint_y: None
            height: dp(24)

        Button:
            text: 'Зарегистрироваться'
            size_hint_y: None
            height: dp(48)
            background_color: 0.2, 0.55, 0.9, 1
            on_press: root.register()
