#:kivy 2.3.1
<LoginScreen@Screen>:
    name: 'LoginScreen'

    BoxLayout:
        orientation: 'vertical'
        padding: dp(16)
        spacing: dp(8)

        Label:
            text: 'Ruble'
            font_size: sp(24)
            bold: True
            color: 0.15, 0.35, 0.65, 1
            size_hint_y: None
            height: dp(40)

        Label:
            text: 'Введите PIN-код'
            size_hint_y: None
            height: dp(24)
            color: 0, 0, 0, 1

        TextInput:
            id: password
            password: True
            multiline: False
            input_filter: 'int'
            max_text_length: 4
            size_hint_y: None
            height: dp(38)
            foreground_color: 0, 0, 0, 1

        Label:
            id: message
            text: ''
            color: 0.8, 0.1, 0.1, 1
            size_hint_y: None
            height: dp(20)

        Button:
            text: 'Войти'
            size_hint_y: None
            height: dp(40)
            background_color: 0.2, 0.55, 0.9, 1
            on_press: root.try_login()