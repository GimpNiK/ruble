#:kivy 2.3.1
#:import check_password models.check_password
<LoginScreen@Screen>:
    name: 'LoginScreen'
    
    BoxLayout:
        orientation: 'vertical'
        #padding: dp(40)
        #spacing: dp(20)
        # canvas.before:
        #     Color:
        #         rgba: 0.2, 0.8, 0.2, 1  # зеленый фон
        #     Rectangle:
        #         size: self.size
        #         pos: self.pos
        
        Label:
            text: 'Введите PIN-код'
        
        TextInput:
            id: password
            password: True
            multiline: False
            input_filter: 'int'
            max_text_length: 4
        Label:
            id: message 
            text: ''  
        Button:
            text: 'Войти'
            on_press: 
                if check_password(password.text): root.manager.current = 'MainScreen'
                else: message.text = "У вас неверный пароль. Повторите попытку"
        
        