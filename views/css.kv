# css.kv
# Стили для всех экранов
<Button>:
    font_size: sp(18)
    background_normal: ''
    background_color: 0.3, 0.6, 0.9, 1
    color: 1, 1, 1, 1
    size_hint_y: None
    height: dp(50)

<Label>:
    font_size: sp(16)
    color: 0.1, 0.1, 0.1, 1

<TextInput>:
    font_size: sp(16)
    size_hint_y: None
    height: dp(50)
    background_color: 1, 1, 1, 1
    foreground_color: 0, 0, 0, 1