# Глобальные стили приложения Ruble

<Button>:
    font_size: sp(15)
    background_normal: ''
    background_color: 0.25, 0.55, 0.85, 1
    color: 1, 1, 1, 1
    size_hint_y: None
    height: dp(44)
    canvas.before:
        Color:
            rgba: self.background_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]

<Label>:
    font_size: sp(14)
    color: 0.15, 0.15, 0.15, 1
    halign: 'left'
    valign: 'middle'

<TextInput>:
    font_size: sp(15)
    background_color: 1, 1, 1, 1
    foreground_color: 0.1, 0.1, 0.1, 1
    padding: dp(10), dp(10)
    multiline: False
    size_hint_y: None
    height: dp(44)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(6)]
        Color:
            rgba: 0.8, 0.8, 0.8, 0.5
        Line:
            rectangle: self.x, self.y, self.width, self.height
            width: 1

<Screen>:
    canvas.before:
        Color:
            rgba: 0.97, 0.98, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size

<BoxLayout>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size